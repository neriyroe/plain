Plain — Examples
Nerijus Ramanauskas <nerijus@signaintermedia.com>


COMMENTS AND WHITESPACE

    ` Backtick starts a comment, ends at the line break.

    Whitespace and commas are interchangeable separators. These are the same:

        add 1, 2
        add 1 2


LITERALS

    ` Booleans
    yes
    no

    ` Nil
    none

    ` Integers
    42
    -7

    ` Reals
    3.14
    1.5e10

    ` Strings (single or double quotes, backslash escapes)
    "hello, world"
    'it\'s fine'


VARIABLES

    ` Assign with set
    set x, 42;
    set name, "Plain"

    ` Read a variable by using its name as an argument
    print x;
    print name


EXPRESSIONS

    ` Wrap any statement in [...] to use its result as a value
    print [add 1, 2];
    print [join "Hello, ", name, "!"];
    set x, [multiply 6, 7]


ARITHMETIC

    ` All operators are regular prefix callables
    print [add 10, 3];          ` 13
    print [subtract 10, 3];     ` 7
    print [multiply 10, 3];     ` 30
    print [divide 10, 3];       ` 3
    print [modulo 10, 3]        ` 1

    ` Symbol aliases are also registered
    print [+ 10, 3];            ` 13
    print [- 10, 3];            ` 7
    print [* 10, 3];            ` 30
    print [/ 10, 3];            ` 3
    print [% 10, 3]             ` 1

    ` Arithmetic operators are variadic — pass as many arguments as you like
    print [+ 1, 2, 3, 4, 5]     ` 15  (folds left to right: 1+2+3+4+5)
    print [* 2, 3, 4]            ` 24  (2*3*4)

    ` Reals promote automatically
    print [add 1, 0.5]           ` 1.5


COMPARISON

    set x, 5;
    print [= x, 5];              ` yes
    print [!= x, 4];             ` yes
    print [< x, 10];             ` yes
    print [> x, 3];              ` yes
    print [<= x, 5];             ` yes
    print [>= x, 5]              ` yes

    ` Named aliases work the same way
    print [equal x, 5];          ` yes
    print [less x, 10];          ` yes
    print [greater x, 3]         ` yes


LOGIC

    print [not yes]              ` no

    ` and/or are variadic prefix callables
    print [and yes, yes, yes];   ` yes
    print [or  no,  no,  yes];   ` yes

    ` Compound conditions
    set x, 5;
    print [and [> x, 0] [< x, 10]];    ` yes
    print [or  [< x, 0] [> x, 3]]      ` yes


STRINGS

    print [join "Hello, ", "world", "!"]    ` Hello, world!

    ` Numbers coerce to strings automatically
    print [join "Result: ", [add 1, 2]]     ` Result: 3

    ` String interpolation — {name} inserts a variable's value
    set name, "world";
    print "Hello, {name}!"                  ` Hello, world!

    ` Expressions inside interpolation use {[...]}
    set x, 6;
    print "{x} * 7 = {[* x, 7]}"           ` 6 * 7 = 42

    ` Multiple interpolations in one string
    set a, 10; set b, 20;
    print "{a} + {b} = {[+ a, b]}"          ` 10 + 20 = 30

    ` Strings without braces are unchanged (zero overhead)
    print "no interpolation here"           ` no interpolation here

    ` Escape braces with backslash to get literal braces
    print "use \{name\} for interpolation"  ` use {name} for interpolation


BLOCKS

    ` Curly braces create a deferred block — not evaluated until needed
    { print "I run when called" }

    ` Colon shorthand: opens a block, semicolon closes it
    : print "same thing";


IF

    set x, 10;

    if [> x, 5] {
        print "big"
    }

    ` With else
    if [> x, 5] {
        print "positive"
    } else {
        print "not positive"
    }

    ` elseif — "else" followed by a condition chains branches;
    ` "else" followed by a block is the final fallback
    set x, 7;
    if [> x, 10] { print "big" } else [> x, 5] { print "medium" } else [> x, 0] { print "small" } else { print "none" }

    ` Colon shorthand (no else)
    if [= x, 10]: print "exactly ten";


WHEN

    ` Value-based dispatch — matches the target against each case
    set x, "b";
    when x
        "a" { print "matched a" }
        "b" { print "matched b" }
        "c" { print "matched c" }
    ` Prints: matched b

    ` With else fallback
    set color, "purple";
    when color
        "red"   { print "warm" }
        "blue"  { print "cool" }
        else    { print "unknown" }
    ` Prints: unknown

    ` Works with integers
    set code, 42;
    when code
        0  { print "zero" }
        1  { print "one" }
        42 { print "the answer" }
    ` Prints: the answer

    ` The target can be an expression
    when [+ 1, 1]
        1 { print "one" }
        2 { print "two" }
        3 { print "three" }
    ` Prints: two


REPEAT

    ` Infinite loop — use break to exit
    set x, 0;
    repeat {
        set x, [+ x, 1];
        if [= x, 3]: break;
    };
    print x    ` 3

    ` Counted loop
    repeat 5 {
        print "hello"
    }

    ` Conditional loop — condition block is re-evaluated each iteration
    set i, 0;
    repeat { < i, 5 } {
        print i;
        set i, [+ i, 1]
    }

    ` Counted loop with automatic variable binding
    repeat {i} times 5 {
        print i
    }
    ` Prints: 0, 1, 2, 3, 4

    ` The variable is scoped to the loop body
    repeat {x} times 3 {
        print x
    };
    ` x is not defined here — clean scope

    ` Nested counted loops
    repeat {y} times 3 {
        repeat {x} times 3 {
            print [join x ", " y]
        }
    }

    ` The modifier keyword "times" is extensible — future modifiers
    ` like "in", "till", "unless" can follow the same pattern


BREAK AND CONTINUE

    ` break exits the nearest repeat
    set i, 0;
    repeat {
        if [= i, 3]: break;
        print i;
        set i, [+ i, 1]
    }
    ` Prints: 0, 1, 2

    ` continue skips to the next iteration
    set i, 0;
    repeat { < i, 6 } {
        set i, [+ i, 1];
        if [= [% i, 2] 0]: continue;
        print i
    }
    ` Prints: 1, 3, 5


DEFINE

    ` Named form — defines a callable and binds it in the current frame
    define square {n} {
        return [* n, n]
    };

    print [square 5]    ` 25

    ` Expression form — [define {parameters} {body}] returns a callable value
    set double, [define {n} { return [* n, 2] }];
    print [double 5]    ` 10

    ` Callables are mutable — rebind a name any time with set
    set double, [define {n} { return [+ n, n] }];
    print [double 5]    ` 10  (still the same result, different implementation)


RETURN

    define clamp {value, minimum, maximum} {
        if [< value, minimum]: return minimum;
        if [> value, maximum]: return maximum;
        return value
    };

    print [clamp 5, 0, 10];      ` 5
    print [clamp -3, 0, 10];     ` 0
    print [clamp 99, 0, 10]      ` 10


NESTED EXPRESSIONS

    define square {n} { return [* n, n] };

    ` Nest expressions freely
    print [add [square 3] [square 4]]    ` 25

    ` Fibonacci
    define fibonacci {n} {
        if [< n, 2]: return n;
        return [+ [fibonacci [- n, 1]] [fibonacci [- n, 2]]]
    };

    print [fibonacci 10]    ` 55


DO

    ` Executes a block in a fresh scope and returns its value.
    ` Variables created inside do not leak into the surrounding frame.

    set result, [do { set x, 6; set y, 7; return [* x, y] }];
    print result    ` 42

    ` do is a regular mutable callable — it can be overridden or passed around
    print [type do]    ` callable


CLOSURES

    ` Callables capture the frame in which they were defined. Outer
    ` variables remain accessible and mutable even after the outer
    ` call returns.

    ` Counter factory — each counter has its own private state
    define make_counter {} {
        set n, 0;
        return [define {} { set n, [+ n, 1]; return n }]
    };

    set counter, [make_counter];
    print [counter];    ` 1
    print [counter];    ` 2
    print [counter]     ` 3

    ` Partial application — capture a parameter as a closed-over variable
    define adder {n} {
        return [define {x} { return [+ x, n] }]
    };

    set add5, [adder 5];
    print [add5 3];     ` 8
    print [add5 10]     ` 15


LISTS

    ` Create a list with initial values
    set items, [list 10, 20, 30];

    ` Access by index (zero-based)
    print [items get 0];       ` 10
    print [items get 2]        ` 30

    ` Modify an element
    items set 1, 99;
    print [items get 1]        ` 99

    ` Append and query length
    items append 42;
    print [items length]       ` 4

    ` Remove by index
    items remove 0;
    print [items get 0]        ` 99

    ` Empty list
    set empty, [list];
    print [empty length]       ` 0

    ` Use a flat list as a 2D grid (10 columns x 3 rows)
    set grid, [list];
    repeat 30 { grid append 0 };

    ` Set cell (2, 1) to 5
    grid set [+ [* 1, 10] 2], 5;

    ` Get cell (2, 1)
    print [grid get [+ [* 1, 10] 2]]    ` 5

    ` Iterate over a list
    set values, [list 1, 2, 3, 4, 5];
    set i, 0;
    repeat [values length] {
        print [values get i];
        set i, [+ i, 1]
    }


OBJECTS (C++ BRIDGE)

    ` The C++ host can register classes with bind_class<T>().
    ` Plain constructs objects and calls methods using bare keywords.

    ` Construct (calls the registered C++ constructor)
    set v, [Vec2 3, 4];

    ` Call methods — the first bare keyword after the object is the method name
    print [v length];          ` 5
    print [v str];             ` Vec2(3, 4)

    ` Method with arguments
    set w, [Vec2 1, 2];
    set u, [v add w];
    print [u str]              ` Vec2(4, 6)

    ` Statement form (no return value needed)
    v draw

    ` If a method name collides with a bound variable, use a quoted string:
    set length, 42;
    print [v "length"]         ` still calls the method, not the variable


TYPE INTROSPECTION

    print [type 42];       ` integer
    print [type 3.14];     ` real
    print [type "hello"];  ` string
    print [type yes];      ` boolean
    print [type none];     ` none

    set fn, [define {x} { return x }];
    print [type fn]        ` callable


MULTIPLE STATEMENTS

    ` Semicolons separate statements on one line
    set a, 1; set b, 2; print [add a, b]    ` 3


FIRST-CLASS CALLABLES

    ` Built-in procedures are regular mutable bindings — store them, pass
    ` them as arguments, and invoke them exactly like user-defined callables.

    ` Store a built-in procedure in a variable
    set branch, if;
    branch yes { print "yes" } { print "no" }    ` yes

    ` Pass a callable as an argument
    define apply {operation, a, b} {
        return [operation a, b]
    };

    print [apply add, 3, 4];         ` 7
    print [apply multiply, 3, 4];    ` 12
    print [apply equal, 5, 5];       ` yes
    print [apply less, 3, 4];        ` yes
    print [apply greater, 4, 3]      ` yes

    ` Works with user-defined callables too
    define twice {f, x} {
        return [f [f x]]
    };

    set double, [define {n} { return [* n, 2] }];
    print [twice double, 3]    ` 12  (3 * 2 * 2)

    ` Override a built-in — no keywords are reserved
    set add, [define {a, b} { return [+ a, b, 1] }];
    print [add 2, 3];    ` 6

    set add, [define {a, b} { return [+ a, b] }];
    print [add 2, 3]     ` 5


CLASSES AND OBJECTS

    ` define is the constructor — a regular callable that returns [object { ... }].
    ` object evaluates its block in a fresh frame and returns it as an object value.

    define Dog {name, age}:
        return [object {
            set name, name;
            set age, age;
            define bark {} {
                print "{name} says Woof!"
            };
            define info {} {
                return "{name}, age: {age}"
            };
            define rename {new_name} {
                set name, new_name
            }
        }]

    ` Create instances
    set dog, [Dog "Rex", 3];
    dog bark;                ` Rex says Woof!
    print [dog info];        ` Rex, age: 3
    print [dog name];        ` Rex  (field set explicitly in the object block)
    print [type dog];        ` object

    ` Mutation through methods
    dog rename "Buddy";
    dog bark;                ` Buddy says Woof!

    ` Multiple independent instances
    set a, [Dog "Alpha", 1];
    set b, [Dog "Beta", 2];
    a bark;                  ` Alpha says Woof!
    b bark                   ` Beta says Woof!

    ` Implicit self — methods reach fields via the closure chain.
    ` self is auto-bound when you need to pass the instance as a value.
    define Node {value}:
        return [object {
            set value, value;
            define get_self {} { return self }
        }]

    set n, [Node 42];
    set ref, [n get_self];   ` ref is the same object as n

    ` Anonymous constructor — assign [define ...] to a variable
    set Cat, [define {name} {
        return [object {
            define meow {} { return "{name} meows" }
        }]
    }];
    set cat, [Cat "Whiskers"];
    print [cat meow]         ` Whiskers meows

    ` Stateful object — counter pattern
    define Counter {}:
        return [object {
            set count, 0;
            define increment {} { set count, [+ count, 1] };
            define value {} { return count }
        }]

    set counter, [Counter];
    counter increment;
    counter increment;
    counter increment;
    print [counter value]    ` 3

    ` Constructor params are visible to methods via closure even without set.
    ` Omitting set name, name makes name inaccessible from outside the object
    ` but methods inside can still use it.
    define Greeter {prefix}:
        return [object {
            define greet {name} { print "{prefix}, {name}!" }
        }]

    set g, [Greeter "Hello"];
    g greet "world"          ` Hello, world!
